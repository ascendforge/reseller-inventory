{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reseller Inventory",
  "version": "1.0.0",
  "identifier": "com.argonexus.reseller-inventory",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Reseller Inventory",
        "width": 1100,
        "height": 780,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
